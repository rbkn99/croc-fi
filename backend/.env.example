# ============================================================
# ProofLayer Backend — Environment Variables
# ============================================================
# Copy to .env and fill in values.
# On Railway: add these in Settings → Variables.
# ============================================================

# --- Database ---
# Railway: auto-provisioned when you add PostgreSQL plugin.
# Copy the DATABASE_URL from Railway PostgreSQL service.
# Local: docker compose up -d → uses default creds below.
DATABASE_URL=postgresql://prooflayer:prooflayer@localhost:5432/prooflayer

# --- Solana ---
# Cluster: devnet | testnet | mainnet-beta
SOLANA_CLUSTER=devnet

# RPC URL — use Helius/Triton for reliability.
# Railway: paste your RPC URL with API key.
# Free RPC (rate limited): https://api.devnet.solana.com
SOLANA_RPC_URL=https://api.devnet.solana.com

# --- Keypairs ---
# Local: paths to JSON keypair files (generated by `npm run setup`)
# Railway: paste the JSON array content directly as env var value,
#   or use ATTESTOR_KEY / ISSUER_KEY instead of file paths.
ATTESTOR_KEY_PATH=./.keys/attestor.json
ISSUER_KEY_PATH=./.keys/issuer.json

# Issuer public key — used by auth middleware to verify issuer role.
# Set to the pubkey of the issuer keypair above.
ISSUER_PUBKEY=
 
# --- Program IDs ---
# Set after deploying Anchor programs to devnet.
ASSET_PUBKEY=
MINT_PUBKEY=
DEFAULT_ASSET_PUBKEY=

# --- API Server ---
# Railway: set to $PORT (Railway injects it automatically).
# Local: 3001 (frontend runs on 3000).
API_PORT=3001

# CORS — comma-separated list of allowed origins.
# Railway: set to your Vercel frontend URL.
# Local: http://localhost:3000
ALLOWED_ORIGINS=http://localhost:3000

# --- JWT Auth ---
# Secret for signing JWT tokens. Use a random 64-char string in production.
# Railway: generate with `openssl rand -hex 32`
JWT_SECRET=dev-secret-change-in-production

# --- Cloudflare R2 (file uploads) ---
# Create bucket at Cloudflare Dashboard → R2 → Create bucket.
# Create API token at R2 → Manage R2 API Tokens → Create API Token.
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=prooflayer-uploads
R2_PUBLIC_URL=

# --- KYC Provider ---
# sumsub | synaps | manual
# manual = auto-approves for testing, no external API needed.
KYC_PROVIDER=manual
KYC_API_KEY=
KYC_API_SECRET=
KYC_WEBHOOK_SECRET=
KYC_BASE_URL=https://api.sumsub.com
KYC_EXPIRY_DAYS=365

# --- Background Jobs ---
# Attestation publish interval (ms). Default: 24h.
ATTESTATION_INTERVAL_MS=86400000

# KYC expiry check interval (ms). Default: 6h.
KYC_EXPIRY_CHECK_INTERVAL_MS=21600000

# --- Yield Sources ---
# Pyth SOFR feed ID (fallback if Treasury Direct API is down)
PYTH_SOFR_FEED_ID=0x734ba2bc1cea4652b0e23f899cc39b3e61f39bfd0f13cc6ef48e718bde57e60e

# Treasury Direct API (primary yield source)
TREASURY_DIRECT_API_URL=https://api.fiscaldata.treasury.gov/services/api/fiscal_service/v2/accounting/od/avg_interest_rates

# USDC mint address (devnet mock or mainnet EPjFWdd5AufqSSqeM2qN1xzybapC8G4wEGGkZwyTDt1v)
USDC_MINT=
