# Database (PostgreSQL via Docker: docker compose up -d)
DATABASE_URL=postgresql://prooflayer:prooflayer@localhost:5432/prooflayer

# Solana cluster: devnet | testnet | mainnet-beta
SOLANA_CLUSTER=devnet
SOLANA_RPC_URL=https://api.devnet.solana.com

# Keypair paths (generated by `npm run setup`)
ATTESTOR_KEY_PATH=./.keys/attestor.json
ISSUER_KEY_PATH=./.keys/issuer.json

# Asset pubkeys (set after deploying programs and creating asset)
ASSET_PUBKEY=
MINT_PUBKEY=

# Attestation interval in milliseconds (default: 24h)
ATTESTATION_INTERVAL_MS=86400000

# API port
API_PORT=3000

# Pyth SOFR feed (Solana mainnet)
PYTH_SOFR_FEED_ID=0x734ba2bc1cea4652b0e23f899cc39b3e61f39bfd0f13cc6ef48e718bde57e60e

# Treasury Direct API
TREASURY_DIRECT_API_URL=https://api.fiscaldata.treasury.gov/services/api/fiscal_service/v2/accounting/od/avg_interest_rates

# KYC Provider: sumsub | synaps | manual
KYC_PROVIDER=manual
KYC_API_KEY=
KYC_API_SECRET=
KYC_WEBHOOK_SECRET=
KYC_BASE_URL=https://api.sumsub.com
KYC_EXPIRY_DAYS=365

# KYC expiry check interval (default: 6 hours)
KYC_EXPIRY_CHECK_INTERVAL_MS=21600000

# USDC mint address (devnet mock or mainnet)
USDC_MINT=

# Default asset pubkey for KYC → whitelist sync (set after creating asset)
DEFAULT_ASSET_PUBKEY=
